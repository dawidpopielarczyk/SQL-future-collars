CREATE DATABASE Moje_zainteresowania;

USE Moje_zainteresowania;


CREATE TABLE Zainteresowania (
  ID INT PRIMARY KEY AUTO_INCREMENT,
  Nazwa VARCHAR(100) NOT NULL,
  Opis TEXT NOT NULL,
  Data_realizacji DATE
);


