CREATE DATABASE Biblioteczka;


USE Biblioteczka;


CREATE TABLE Biblioteczka (
  ID INT,
  Tytul TEXT,
  Data_zakupu DATE
);


INSERT INTO Biblioteczka (ID, Tytul, Data_zakupu)
VALUES (1, 'Harry Potter', '1997-01-01');


SELECT * FROM Biblioteczka;


